{
  "name": "unchartedwaters2-electron",
  "productName": "Uncharted Waters 2",
  "version": "1.0.0",
  "description": "Uncharted Waters 2 - DOS Game Emulator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "cd unchartedwaters2 && npm run build",
    "build:all": "npm run build && npm run package",
    "package": "electron-builder --mac --win --linux",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "dev": "npm run build && npm start"
  },
  "keywords": [
    "electron",
    "dos",
    "game",
    "uncharted-waters"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "com.unchartedwaters2.app",
    "productName": "Uncharted Waters 2",
    "files": [
      "main.js",
      "preload.js",
      "unchartedwaters2/dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "unchartedwaters2/dist/favicon.ico"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "unchartedwaters2/dist/favicon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game"
    }
  }
}
